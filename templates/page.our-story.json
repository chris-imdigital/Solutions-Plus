        "intro": {
          "type": "text",
          "settings": {
            "text": "<p>We are a <strong>family-owned</strong> wholesale nursery dedicated to growing the highest quality plants. Located in southern <strong>New Jersey</strong>, we partner exclusively with <strong>locally-owned</strong> garden centers in the Northeast and Mid-Atlantic. Environmentally conscious since our founding in <strong>1952</strong>, we are proud to be <strong>Veriflora\u00ae</strong> certified.</p>",
            "width": "100%",
            "max_width": "narrow",
            "type_preset": "rte",
            "alignment": "center",
            "padding-block-start": 0,
            "padding-block-end": 0
