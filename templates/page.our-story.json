    "narrative_text": {
      "type": "_blocks",
      "blocks": {
        "paragraph_1": {
          "type": "text",
          "settings": {
            "text": "<p>Our story begins in 1952 when John and Jean Overdevest emigrated from Holland, settling in southern New Jersey. With a deep love for horticulture and a vision for growing quality plants, they started the nursery with a focus on Azaleas, Rhododendrons, Dogwoods, and Japanese Maples.</p>",
            "width": "100%",
            "max_width": "narrow",
            "type_preset": "rte",
            "alignment": "center",
            "padding-block-start": 0,
            "padding-block-end": 0
          }
        },
        "paragraph_2": {
          "type": "text",
          "settings": {
            "text": "<p>Now in the third generation, our company continues to emphasize quality, sustainability, and a passionate team that honors the founders' principles. Every plant we grow reflects our commitment to the land and the independent garden centers we proudly serve.</p>",
            "width": "100%",
            "max_width": "narrow",
            "type_preset": "rte",
            "alignment": "center",
            "padding-block-start": 0,
            "padding-block-end": 0
          }
        }
      },
      "block_order": ["paragraph_1", "paragraph_2"],
      "settings": {
        "content_direction": "column",
        "horizontal_alignment_flex_direction_column": "center",
        "vertical_alignment_flex_direction_column": "center",
        "gap": 24,
        "section_width": "page-width",
        "section_height": "",
        "color_scheme": "scheme-1",
        "padding-block-start": 20,
        "padding-block-end": 60
      }
    },
